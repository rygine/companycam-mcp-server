{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortImports": {
    "internalPattern": ["@/", "@test/"]
  },
  "sortPackageJson": true,
  "ignorePatterns": [".yarn", ".output", ".vinxi", "**/*.timestamp_*.js"]
}
