{
  "name": "companycam-mcp-server",
  "version": "0.0.2",
  "description": "MCP server exposing the CompanyCam API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown",
    "bundle": "tsx scripts/build-mcpb.ts",
    "bundle:validate": "mcpb validate mcpb-build/manifest.json",
    "claude-config": "tsx src/scripts/print-claude-config.ts",
    "clean": "rimraf node_modules dist mcpb-build",
    "deploy": "wrangler deploy",
    "dev:worker": "wrangler dev",
    "fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "generate": "tsx src/tools/convert.ts",
    "lint": "oxlint .",
    "start": "tsx src/index.ts",
    "stdio": "tsx src/index.ts --stdio",
    "typecheck": "tsc && tsc -p tsconfig.worker.json"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "yarn@4.17.1"
}
